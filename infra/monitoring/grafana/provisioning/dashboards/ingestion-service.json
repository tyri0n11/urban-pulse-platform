{
  "uid": "ingestion-service",
  "title": "03 Services - Ingestion",
  "description": "Real-time monitoring of VietMap API ingestion pipeline for Ho Chi Minh City traffic routes. Tracks API latency, errors, and data quality metrics.",
  "tags": [
    "urban-pulse",
    "services",
    "ingestion",
    "traffic"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 3,
      "type": "stat",
      "title": "Routes Failed",
      "description": "Number of routes that failed to fetch from VietMap API during the selected time range. Critical issue if > 5 routes.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "count_over_time({service=\"traffic-ingestion-service\"} |= \"Failed to fetch route\" [$__range])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "rgba(34, 209, 102, 0.2)",
                "value": null
              },
              {
                "color": "rgba(255, 193, 7, 0.2)",
                "value": 1
              },
              {
                "color": "rgba(244, 67, 54, 0.2)",
                "value": 3
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": []
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Rate Limit (429)",
      "description": "VietMap API 429 Too Many Requests errors. Indicates request throttling—consider exponential backoff or circuit breaker.",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "count_over_time({service=\"traffic-ingestion-service\"} |= \"Failed to fetch route\" |~ \"429|Too Many Requests\" [$__range])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": []
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Errors",
      "description": "Cumulative error count across all API operations and pipeline stages. Includes timeouts, network errors, and parsing failures.",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "count_over_time({service=\"traffic-ingestion-service\"} |= \"ERROR\" [$__range])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": []
        }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "API Latency p95",
      "description": "95th percentile of per-route API response time (last 10 min). SLO: < 500ms. Yellow > 500ms, Red > 2000ms.",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.95, {service=\"traffic-ingestion-service\"} |= \"latency_api_ms\" | pattern `<_> latency_api_ms=<lat>` | unwrap lat | __error__=\"\" [10m])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 500
              },
              {
                "color": "red",
                "value": 2000
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          },
          "mappings": []
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "API Latency Distribution (per route)",
      "description": "P50 (median) / P90 / P95 percentiles of per-route API response time. Green = healthy, Yellow = caution, Red = SLO breach.",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.50, {service=\"traffic-ingestion-service\"} |= \"latency_api_ms\" | pattern `<_> latency_api_ms=<lat>` | unwrap lat | __error__=\"\" [2m])",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.90, {service=\"traffic-ingestion-service\"} |= \"latency_api_ms\" | pattern `<_> latency_api_ms=<lat>` | unwrap lat | __error__=\"\" [2m])",
          "legendFormat": "P90"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.95, {service=\"traffic-ingestion-service\"} |= \"latency_api_ms\" | pattern `<_> latency_api_ms=<lat>` | unwrap lat | __error__=\"\" [2m])",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "P50"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#22d166",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "solid"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "P90"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#ffc107",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "solid"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "P95"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#f44336",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "solid"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Log Rate by Severity",
      "description": "Request rate per second grouped by log level. Watch for spikes in ERROR or WARNING levels.",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum by (level) (rate({service=\"traffic-ingestion-service\"}[1m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 15,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "error"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#f44336",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "warning"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#ff9800",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "info"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "#2196f3",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 11,
      "type": "logs",
      "title": "Critical Issues (Errors & Failed Routes)",
      "description": "Error logs and route fetch failures. Use to diagnose API issues, rate limiting, or data quality problems.",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"traffic-ingestion-service\"} |~ \"ERROR|Failed to fetch|Too Many Requests\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 12,
      "type": "logs",
      "title": "Recent Activity",
      "description": "All ingestion service logs. Expand entries for detailed context including route ID, latency, and response codes.",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"traffic-ingestion-service\"}"
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "enableLogDetails": true
      }
    }
  ]
}
