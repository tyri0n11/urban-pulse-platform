{
  "uid": "serving-api",
  "title": "Serving API — Requests, RCA & Telegram",
  "tags": ["serving", "rca", "telegram", "urban-pulse"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 39,
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Total Logs",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count_over_time({service=\"serving-service\"}[$__range])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Errors",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count_over_time({service=\"serving-service\"} |= \"ERROR\" [$__range])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "RCA Requests",
      "description": "POST /rca calls counted from log lines containing 'rca: route='",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count_over_time({service=\"serving-service\"} |= \"rca: route=\" [$__range])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Telegram Messages Handled",
      "description": "Telegram webhook messages counted from 'telegram: chat_id=' log lines",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count_over_time({service=\"serving-service\"} |= \"telegram: chat_id=\" [$__range])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "teal" } } }
    },

    {
      "id": 5,
      "type": "stat",
      "title": "LLM Errors",
      "description": "Ollama timeout / connection errors from RCA or Telegram handlers",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count_over_time({service=\"serving-service\"} |~ \"LLM timeout|Ollama error|LLM call failed\" [$__range])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 6,
      "type": "stat",
      "title": "Telegram Send Failures",
      "description": "Telegram API delivery failures: 'telegram: send failed'",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count_over_time({service=\"serving-service\"} |= \"telegram: send failed\" [$__range])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] },
          "color": { "mode": "thresholds" }
        }
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Log Rate by Level",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (rate({service=\"serving-service\"}[1m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 5 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARNING" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "RCA Request Rate",
      "description": "Rate of POST /rca calls (one log line per request: 'rca: route=')",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "rate({service=\"serving-service\"} |= \"rca: route=\" [5m])",
          "legendFormat": "rca requests/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 10 }, "color": { "mode": "fixed", "fixedColor": "purple" } }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Telegram Message Rate",
      "description": "Rate of Telegram webhook messages handled (one log per handled message)",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "rate({service=\"serving-service\"} |= \"telegram: chat_id=\" [5m])",
          "legendFormat": "messages/s"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "rate({service=\"serving-service\"} |= \"telegram: send failed\" [5m])",
          "legendFormat": "send failures/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 8 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "messages/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "teal", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "send failures/s" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 10,
      "type": "timeseries",
      "title": "LLM Errors Over Time",
      "description": "Ollama timeout / connection errors from RCA and Telegram handlers",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "rate({service=\"serving-service\"} |~ \"LLM timeout|Ollama error|LLM call failed\" [5m])",
          "legendFormat": "llm errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 8 }, "color": { "mode": "fixed", "fixedColor": "orange" } }
      }
    },

    {
      "id": 11,
      "type": "logs",
      "title": "Error Logs",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"serving-service\"} |= \"ERROR\""
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    },

    {
      "id": 12,
      "type": "logs",
      "title": "Recent Serving Logs",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"serving-service\"}"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": false, "sortOrder": "Descending", "enableLogDetails": true }
    }

  ]
}
