{
  "uid": "ml-model-insights",
  "title": "ML Model Insights",
  "tags": [
    "ml",
    "anomaly",
    "urban-pulse",
    "thesis"
  ],
  "timezone": "browser",
  "refresh": "5m",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Routes Trained (Last Run)",
      "description": "Number of per-route IsolationForest models trained in the most recent run",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "last_over_time({service=\"ml-service\"} |= \"Per-route training complete\" | pattern `<_>\u2014 <trained>/<_> routes trained<_>` | unwrap trained | __error__=\"\" [$__range])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 15
              },
              {
                "color": "green",
                "value": 20
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Training Samples (Last Run)",
      "description": "Total samples across all routes in the most recent training run",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "last_over_time({service=\"ml-service\"} |= \"Per-route training complete\" | pattern `<_> routes trained, <samples> total samples` | unwrap samples | __error__=\"\" [$__range])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg IForest Anomalies per Route",
      "description": "Average IsolationForest anomaly count across all per-route training runs",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "avg_over_time({service=\"ml-service\"} |= \"iforest=\" |= \"anomalies\" | pattern `<_>iforest=<n> anomalies<_>` | unwrap n | __error__=\"\" [$__range])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 60
              },
              {
                "color": "red",
                "value": 100
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Model Agreement",
      "description": "Average agreement between Z-score and IsolationForest across all routes",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "avg_over_time({service=\"ml-service\"} |= \"agreement=\" | pattern `<_>agreement=<a>` | unwrap a | __error__=\"\" [$__range])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.85
              },
              {
                "color": "green",
                "value": 0.95
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Total IForest Anomalies Over Time (all routes)",
      "description": "IsolationForest anomaly counts per route across training runs",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum_over_time({service=\"ml-service\"} |= \"iforest=\" |= \"anomalies\" | pattern `<_>iforest=<n> anomalies<_>` | unwrap n | __error__=\"\" [$__interval])",
          "legendFormat": "IForest Anomalies (all routes)"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Avg Model Agreement Over Time (all routes)",
      "description": "Agreement between Z-score and IsolationForest signals per route",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "avg_over_time({service=\"ml-service\"} |= \"agreement=\" | pattern `<_>agreement=<a>` | unwrap a | __error__=\"\" [$__interval])",
          "legendFormat": "Avg Agreement"
        }
      ],
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0,
          "max": 1
        }
      }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "ML Training Run Events",
      "description": "Per-route training logs and parent run summaries",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"ml-service\"} |~ \"(Per-route training complete|route=zone.*trained|IsolationForest: trained|Starting per-route)\""
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ]
}
