{
  "uid": "streaming-service",
  "title": "Streaming Service",
  "tags": ["streaming", "urban-pulse"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Logs",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count_over_time({service=\"streaming-service\"}[$__range])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Errors",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count_over_time({service=\"streaming-service\"} |= \"ERROR\" [$__range])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Flushes",
      "description": "Number of batch writes to MinIO",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count_over_time({service=\"streaming-service\"} |= \"Flushed\" [$__range])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Records Written to MinIO",
      "description": "Extracted from 'Flushed N records' log lines",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum_over_time({service=\"streaming-service\"} |= \"Flushed\" | regexp `Flushed (?P<records>\\d+) records` | unwrap records | __error__=\"\" [$__range])"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Log Rate by Level",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (rate({service=\"streaming-service\"}[1m]))",
          "legendFormat": "{{level}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARNING" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "MinIO Flush Rate",
      "description": "Batch writes to MinIO per minute",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "rate({service=\"streaming-service\"} |= \"Flushed\" [1m])",
          "legendFormat": "flushes/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Error Logs",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"streaming-service\"} |= \"ERROR\""
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": true, "sortOrder": "Descending" }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "MinIO Write Events",
      "description": "All successful flush log lines",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"streaming-service\"} |= \"Flushed\""
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": false, "sortOrder": "Descending" }
    },
    {
      "id": 9,
      "type": "logs",
      "title": "Recent Logs",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"streaming-service\"}"
        }
      ],
      "options": { "showTime": true, "wrapLogMessage": false, "sortOrder": "Descending", "enableLogDetails": true }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Traffic Buffer Size",
      "description": "Current number of records in the MinIO write buffer (max 10)",
      "gridPos": { "x": 0, "y": 28, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "last_over_time({service=\"streaming-service\"} |= \"buffer_size=\" | regexp `buffer_size=(?P<size>\\d+)` | unwrap size | __error__=\"\" [10s])",
          "legendFormat": "buffer size"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 10,
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7 },
              { "color": "red", "value": 10 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "options": { "tooltip": { "mode": "single" } }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "E2E Latency P50 / P90 / P95",
      "description": "End-to-end latency from ingestion to streaming processing",
      "gridPos": { "x": 0, "y": 36, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.50, {service=\"streaming-service\"} |= \"latency_e2e_ms\" | pattern `<_> latency_e2e_ms=<latency> <_>` | unwrap latency | __error__=\"\" [5m]) by (service)",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.90, {service=\"streaming-service\"} |= \"latency_e2e_ms\" | pattern `<_> latency_e2e_ms=<latency> <_>` | unwrap latency | __error__=\"\" [5m]) by (service)",
          "legendFormat": "P90"
        },
        {
          "refId": "C",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {service=\"streaming-service\"} |= \"latency_e2e_ms\" | pattern `<_> latency_e2e_ms=<latency> <_>` | unwrap latency | __error__=\"\" [5m]) by (service)",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P50" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P90" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Processing Latency P90 / P95",
      "description": "Time to process each message in the streaming service",
      "gridPos": { "x": 12, "y": 36, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.90, {service=\"streaming-service\"} |= \"latency_processing_ms\" | pattern `<_> latency_processing_ms=<latency> <_>` | unwrap latency | __error__=\"\" [5m]) by (service)",
          "legendFormat": "P90"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {service=\"streaming-service\"} |= \"latency_processing_ms\" | pattern `<_> latency_processing_ms=<latency> <_>` | unwrap latency | __error__=\"\" [5m]) by (service)",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P90" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Flush Latency P90 / P95",
      "description": "Time to write buffered records to MinIO",
      "gridPos": { "x": 0, "y": 44, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.90, {service=\"streaming-service\"} |= \"latency_flush_ms\" | pattern `<_> latency_flush_ms=<latency> records=<_>` | unwrap latency | __error__=\"\" [5m]) by (service)",
          "legendFormat": "P90"
        },
        {
          "refId": "B",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "quantile_over_time(0.95, {service=\"streaming-service\"} |= \"latency_flush_ms\" | pattern `<_> latency_flush_ms=<latency> records=<_>` | unwrap latency | __error__=\"\" [5m]) by (service)",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "P90" }, "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "P95" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] }
        ]
      }
    }
  ]
}
