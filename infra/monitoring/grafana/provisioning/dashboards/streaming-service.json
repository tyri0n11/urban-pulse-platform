{
  "uid": "streaming-service",
  "title": "04 Services - Streaming",
  "tags": [
    "urban-pulse",
    "services",
    "streaming",
    "bronze"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 2,
      "type": "stat",
      "title": "Errors",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "count_over_time({service=\"streaming-service\"} |= \"ERROR\" [$__range])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Flushes",
      "description": "Number of successful batch writes to MinIO",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "count_over_time({service=\"streaming-service\"} |= \"Flushed\" [$__range])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Records Written to MinIO",
      "description": "Extracted from 'Flushed N records' log lines",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum_over_time({service=\"streaming-service\"} |= \"Flushed\" | regexp `Flushed (?P<records>\\d+) records` | unwrap records | __error__=\"\" [$__range])"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Error Logs",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"streaming-service\"} |= \"ERROR\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "E2E Latency P50 P90 P95",
      "description": "End-to-end latency from ingestion to streaming processing",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.50, {service=\"streaming-service\"} |= \"latency_e2e_ms\" | pattern `<_> latency_e2e_ms=<latency> <_>` | unwrap latency | __error__=\"\" [5m]) by (service)",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.90, {service=\"streaming-service\"} |= \"latency_e2e_ms\" | pattern `<_> latency_e2e_ms=<latency> <_>` | unwrap latency | __error__=\"\" [5m]) by (service)",
          "legendFormat": "P90"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.95, {service=\"streaming-service\"} |= \"latency_e2e_ms\" | pattern `<_> latency_e2e_ms=<latency> <_>` | unwrap latency | __error__=\"\" [5m]) by (service)",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "P50"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "P90"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "P95"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
