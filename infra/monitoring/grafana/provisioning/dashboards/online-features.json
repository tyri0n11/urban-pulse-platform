{
  "uid": "online-features",
  "title": "10 Online - Features",
  "tags": [
    "urban-pulse",
    "online",
    "features",
    "realtime"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Routes",
      "description": "Routes with updates in last 10 minutes",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "SELECT COUNT(DISTINCT route_id) AS value FROM (SELECT DISTINCT ON (route_id) route_id, updated_at FROM online_route_features ORDER BY route_id, updated_at DESC) t WHERE updated_at > NOW() - INTERVAL '10 minutes'",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Baseline Coverage",
      "description": "Active routes with non-null z-score",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "SELECT ROUND(100.0 * SUM(CASE WHEN duration_zscore IS NOT NULL THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 1) AS value FROM (SELECT DISTINCT ON (route_id) route_id, duration_zscore, updated_at FROM online_route_features ORDER BY route_id, updated_at DESC) t WHERE updated_at > NOW() - INTERVAL '10 minutes'",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 70
              },
              {
                "color": "green",
                "value": 90
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Mean Heavy Ratio",
      "description": "Average of latest mean_heavy_ratio per route",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "SELECT ROUND(AVG(mean_heavy_ratio)::numeric, 4) AS value FROM (SELECT DISTINCT ON (route_id) route_id, mean_heavy_ratio, updated_at FROM online_route_features ORDER BY route_id, updated_at DESC) t WHERE updated_at > NOW() - INTERVAL '10 minutes'",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Observations",
      "description": "Sum of latest observation_count across routes",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "SELECT SUM(observation_count) AS value FROM (SELECT DISTINCT ON (route_id) route_id, observation_count FROM online_route_features ORDER BY route_id, updated_at DESC) t",
          "format": "table"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Heavy Ratio Trend",
      "description": "p50 and p95 of mean_heavy_ratio over time",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "SELECT DATE_TRUNC('minute', updated_at) AS time, PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY mean_heavy_ratio) AS p50_heavy_ratio, PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY mean_heavy_ratio) AS p95_heavy_ratio FROM online_route_features WHERE $__timeFilter(updated_at) GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Observation Count Trend",
      "description": "Total observations and active route count over time",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "SELECT DATE_TRUNC('minute', updated_at) AS time, SUM(observation_count) AS total_observations, COUNT(DISTINCT route_id) AS active_routes FROM (SELECT DISTINCT ON (route_id, DATE_TRUNC('minute', updated_at)) route_id, updated_at, observation_count FROM online_route_features WHERE $__timeFilter(updated_at) ORDER BY route_id, DATE_TRUNC('minute', updated_at), updated_at DESC) t GROUP BY 1 ORDER BY 1",
          "format": "time_series"
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Current Online Features",
      "description": "Latest feature snapshot per route",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "rawSql": "SELECT route_id, window_start AT TIME ZONE 'UTC' AS window_start, updated_at AT TIME ZONE 'UTC' AS last_updated, observation_count, ROUND(mean_duration_minutes::numeric, 2) AS mean_duration_min, ROUND(stddev_duration_minutes::numeric, 2) AS stddev_duration_min, ROUND(last_duration_minutes::numeric, 2) AS last_duration_min, ROUND(mean_heavy_ratio::numeric, 4) AS mean_heavy_ratio, ROUND(duration_zscore::numeric, 3) AS zscore, is_anomaly, last_ingest_lag_ms AS lag_ms FROM (SELECT DISTINCT ON (route_id) * FROM online_route_features ORDER BY route_id, updated_at DESC) t ORDER BY ABS(COALESCE(duration_zscore, 0)) DESC",
          "format": "table"
        }
      ],
      "options": {
        "sortBy": [
          {
            "displayName": "zscore",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "filterable": true,
            "displayMode": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "zscore"
            },
            "properties": [
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 2
                    },
                    {
                      "color": "red",
                      "value": 3
                    }
                  ]
                }
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "is_anomaly"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "lag_ms"
            },
            "properties": [
              {
                "id": "unit",
                "value": "ms"
              }
            ]
          }
        ]
      }
    }
  ]
}
