{
  "uid": "online-service",
  "title": "05 Services - Online",
  "description": "Kafka consumer vietmap-raw → Postgres (online_route_features). Loki logs; dữ liệu bảng xem thêm 11 Online - Features / 12 Online - Metrics.",
  "tags": [
    "urban-pulse",
    "services",
    "online",
    "kafka",
    "postgres"
  ],
  "timezone": "browser",
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Errors",
      "description": "Python logging ERROR/CRITICAL (online-service dùng format không khớp parser level của Promtail).",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"online-service\"} |~ \"\\\\s(ERROR|CRITICAL)\\\\s\" [$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Warnings",
      "description": "Cảnh báo (parse lỗi, DLQ, mất kết nối Postgres, v.v.).",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"online-service\"} |~ \"\\\\sWARNING\\\\s\" [$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Feature writes",
      "description": "Số dòng log sau mỗi lần cập nhật feature (online-features: route=...).",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"online-service\"} |= \"online-features: route=\" [$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DLQ routed",
      "description": "Tin lỗi xử lý được gửi sang topic vietmap-raw-dlq.",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"online-service\"} |= \"routing to DLQ\" [$__range]))"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "textMode": "auto",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Ingest lag (lag_ms) P50 P90 P95",
      "description": "Độ trễ ingest từ header ingest_ts đến khi xử lý (ms), trích từ log.",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.50, {service=\"online-service\"} |= \"online-features: route=\" |= \"lag_ms=\" | regexp \"lag_ms=(?P<lag>\\\\d+)\" | unwrap lag | __error__=\"\" [5m])",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.90, {service=\"online-service\"} |= \"online-features: route=\" |= \"lag_ms=\" | regexp \"lag_ms=(?P<lag>\\\\d+)\" | unwrap lag | __error__=\"\" [5m])",
          "legendFormat": "P90"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "quantile_over_time(0.95, {service=\"online-service\"} |= \"online-features: route=\" |= \"lag_ms=\" | regexp \"lag_ms=(?P<lag>\\\\d+)\" | unwrap lag | __error__=\"\" [5m])",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "P50"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "P90"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "P95"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Feature write rate",
      "description": "Số log cập nhật feature theo từng bước thời gian.",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 24,
        "h": 7
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service=\"online-service\"} |= \"online-features: route=\" [$__interval]))",
          "legendFormat": "writes"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2
          }
        }
      }
    },
    {
      "id": 7,
      "type": "logs",
      "title": "Pipeline activity",
      "description": "Subscribe, feature updates, shutdown.",
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"online-service\"} |~ \"online-features: (subscribed|route=|stopped cleanly|shutdown)\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 8,
      "type": "logs",
      "title": "Issues (errors, DLQ, parse, Postgres)",
      "gridPos": {
        "x": 12,
        "y": 19,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{service=\"online-service\"} |~ \"parse error|routing to DLQ|Postgres connection lost|failed to publish to DLQ|\\\\s(ERROR|CRITICAL)\\\\s\""
        }
      ],
      "options": {
        "showTime": true,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
