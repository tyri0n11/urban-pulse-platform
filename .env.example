# MinIO — MINIO_ROOT_USER/PASSWORD are used by the MinIO server container.
# Docker Compose maps these to MINIO_ACCESS_KEY/SECRET_KEY for app services automatically.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# VietMap
VIETMAP_API_KEY=

# Set to true to print messages to stdout instead of publishing to Kafka (no broker required)
DRY_RUN=false

# Path to routes definition file (default: routes.json in cwd)
ROUTES_FILE=routes.json
