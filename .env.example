# Production environment — copy to .env.prod and fill in real values
# chmod 600 .env.prod   (restrict read access)

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# Use strong random passwords in production
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ---------------------------------------------------------------------------
# Nessie (Iceberg catalog) — uses MinIO credentials for S3 access
# ---------------------------------------------------------------------------
NESSIE_S3_ACCESS_KEY=minioadmin
NESSIE_S3_SECRET_KEY=minioadmin

# ---------------------------------------------------------------------------
# PostgreSQL (online feature store)
# ---------------------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# ---------------------------------------------------------------------------
# ---------------------------------------------------------------------------
# Dremio admin credentials
# ---------------------------------------------------------------------------
DREMIO_ADMIN_USER=admin
DREMIO_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# VietMap API key (traffic data source)
# ---------------------------------------------------------------------------
VIETMAP_API_KEY=
