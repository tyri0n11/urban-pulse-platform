# Production environment — copy to .env.prod and fill in real values
# chmod 600 .env.prod   (restrict read access)

# ---------------------------------------------------------------------------
# MinIO (S3-compatible object storage)
# Use strong random passwords in production
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=

# ---------------------------------------------------------------------------
# Nessie (Iceberg catalog) — uses MinIO credentials for S3 access
# ---------------------------------------------------------------------------
NESSIE_S3_ACCESS_KEY=minioadmin
NESSIE_S3_SECRET_KEY=

# ---------------------------------------------------------------------------
# PostgreSQL (online feature store)
# ---------------------------------------------------------------------------
POSTGRES_USER=urbanpulse
POSTGRES_PASSWORD=

# ---------------------------------------------------------------------------
# VietMap API key (traffic data source)
# ---------------------------------------------------------------------------
VIETMAP_API_KEY=

# ---------------------------------------------------------------------------
# Public API URL (used to build the Next.js UI)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.tyr1on.io.vn
NEXT_PUBLIC_TRAFFIC_SSE_URL=https://api.tyr1on.io.vn/events/traffic
